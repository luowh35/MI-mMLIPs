{
  "data": {
    "train_files": [  // 训练集 extxyz 文件列表；可放 1 个或多个文件，按帧拼接为总训练池
      "pw_Fe16.extxyz",  // 平面波 Fe16 数据
      "lcao_Fe16.extxyz",  // LCAO Fe16 数据
      "pw_Fe32.extxyz",  // 平面波 Fe32 数据
      "lcao_Fe32.extxyz"  // LCAO Fe32 数据
    ],
    "val_files": [],  // 验证集 extxyz 文件列表；为空时将从 train_files 内按 val_ratio 随机切分
    "val_ratio": 0.1,  // 当 val_files 为空时，随机划分出的验证集比例
    "split_mode": "source_file",  // 切分模式：source_file / config_type / set / block / random
    "split_group_key": "source_file",  // 分组键（source_file / config_type / set）；block 模式下表示轨迹来源键
    "split_block_size": 50,  // block 模式下每个连续轨迹块包含的帧数
    "max_train_frames_per_file": null,  // 每个训练文件最多读取多少帧；null 表示读取该文件全部帧（正式训练建议改成 null）
    "max_val_frames_per_file": null  // 每个验证文件最多读取多少帧；null 表示读取全部帧
  },

  "model": {
    "cutoff": 4.5,  // 邻居截断半径（单位与坐标一致）；越大信息越多但计算越重
    "num_radial": 6,  // 径向基函数个数 n；描述符维度与计算量随其增加
    "l_max": 2,  // Legendre 角向最高阶 l；控制三体角分辨率
    "rho_u_basis": "legendre",  // rho_u 基函数：power / legendre
    "rho_u_degree": 4,  // rho_u 阶数；legendre 模式下对应 P1..P_degree
    "u_norm_mode": "dataset",  // 模长归一化：dataset / dual
    "mag_ref": 2.2,  // 兜底参考磁矩（当 m_stat 为空时用于 |m|^2 归一化）
    "m_stat": null,  // dataset/dual 模式下可手动指定统计尺度；null 表示自动估计
    "m_stat_mode": "mean",  // 自动估计方式：mean / median / quantile
    "m_stat_quantile": 0.5,  // quantile 模式的分位点
    "u_center": null,  // rho_u 中心化参数（null 表示自动用参考尺度）
    "u_scale": null,  // rho_u 标准化参数（null 表示自动用参考尺度）
    "include_s2": true,  // 是否包含 rho_{s^2} 通道：sum_j f(r_ij) (m_i·m_j)^2
    "include_imm": false,  // 是否包含 A^(imm) 通道，即 (m_i·m_j)(m_i·m_k) 的三体磁项
    "hidden_dim": 128,  // 局域 MLP 隐层宽度
    "depth": 3  // 局域 MLP 深度（线性层总数，>=2）
  },

  "training": {
    "epochs": 10,  // 总训练轮数
    "lr": 0.001,  // Adam 学习率
    "weight_decay": 0.000001,  // Adam 权重衰减（L2 正则）
    "seed": 42,  // 随机种子（影响数据切分、参数初始化、shuffle）
    "batch_size": 1,  // 若显存仍很低且 CPU 忙，可先固定小 batch，优先提速数据/descriptor 管线
    "num_workers": 4,  // DataLoader 子进程数；建议 0->2->4 逐步测试吞吐
    "pin_memory": true,  // CUDA 训练时建议开启，可减少 H2D 拷贝等待
    "persistent_workers": true,  // num_workers>0 时保留 worker，减少每个 epoch 重启开销
    "prefetch_factor": 2,  // 每个 worker 预取 batch 数；仅在 num_workers>0 时生效
    "energy_per_atom": true  // 能量损失是否按每原子归一化（推荐 true，减少 Fe16/Fe32 尺度差异）
  },

  "loss": {
    "use_mag_loss": true,  // 是否使用磁梯度监督项（需要 extxyz 中含 magnetic_force）
    "w_energy": 1.0,  // 能量损失权重
    "w_force": 20.0,  // 原子力损失权重
    "w_mag": 1.0  // 磁梯度损失权重
  },

  "output": {
    "output_dir": "runs/train_from_json",  // 训练输出目录（日志、checkpoint、解析后的配置）
    "save_last": true,  // 是否保存最后一轮 checkpoint 到 last.pt
    "save_best": true,  // 是否按验证损失保存最佳 checkpoint 到 best.pt
    "save_every_epoch": false  // 是否每个 epoch 都额外保存一个 checkpoint（会占较多磁盘）
  },

  "runtime": {
    "device": "cuda"  // 训练设备：\"cpu\" 或 \"cuda\"
  }
}
